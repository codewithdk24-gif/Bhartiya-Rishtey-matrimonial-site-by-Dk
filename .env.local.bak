# ===========================================
# Vows & Heritage - Environment Configuration
# ===========================================

# DATABASE (Using SQLite for local dev - no external DB needed)
DATABASE_URL="file:./prisma/dev.db"

# JWT SECRET (used for session tokens)
JWT_SECRET="vows-heritage-dev-secret-key-change-in-production-2024"

# APP URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"

# SOCKET SERVER
SOCKET_PORT=3001

# CLOUDINARY (optional - payment receipts upload)
# Leave blank to skip Cloudinary features
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# RAZORPAY (optional - payment gateway)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# UPSTASH REDIS (optional - rate limiting)
# If not set, mock limiter is used (all requests pass)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
